# Intent-Aware Network Stack Configuration

# Application
DEBUG=false
ENV=production

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./intent_network.db

# Security
SECRET_KEY=change-this-to-a-secure-random-key-in-production

# ML Configuration
MODEL_PATH=models/trained_models
PREDICTION_THRESHOLD=0.85

# Network Capture
CAPTURE_INTERFACE=
FLOW_TIMEOUT_SECONDS=60

# QoS Configuration
QOS_ENABLED=true
DEFAULT_BANDWIDTH_Mbps=1000
QUEUE_LIMIT=1000

# Logging
LOG_LEVEL=INFO